{
  "name": "pod-design-generator",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "server": "tsx server/index.ts",
    "client": "vite dev",
    "dev": "npm-run-all --parallel server client",
    "build": "vite build && esbuild server/index.ts --bundle --platform=node --outfile=dist/index.cjs --format=cjs --packages=external",
