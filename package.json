    "drizzle-orm": "^0.30.9",
    "drizzle-zod": "^0.5.0",
    "esbuild": "^0.21.5",
    "express": "^4.19.2",
    "groq-sdk": "^0.37.0",
    "lucide-react": "^0.424.0",
    "npm-run-all": "^4.1.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.51.3",
    "react-router-dom": "^6.23.1",
    "sharp": "^0.33.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.7",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.3",
    "@vitejs/plugin-react": "^4.2.1",
    "drizzle-kit": "^0.20.14",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.6",
    "tsx": "^4.7.1",
